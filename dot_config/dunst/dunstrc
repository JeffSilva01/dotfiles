[global]
    font = JetBrainsMono Nerd Font 10
    frame_color = "#7aa2f7"
    separator_color = "#7aa2f7"
    corner_radius = 8
    transparency = 10

[urgency_low]
    background = "#1a1b26"
    foreground = "#c0caf5"
    timeout = 3

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    timeout = 5

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
