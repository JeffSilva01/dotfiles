  },
  "power-profiles-daemon": {
    "format": "{icon} ",
    "tooltip-format": "Perfil de Energia: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’ā¦",
      "performance": "’ā¦",
      "balanced": "’ēÄ",
      "power-saver": "’ü¼"
    }
  }
}
