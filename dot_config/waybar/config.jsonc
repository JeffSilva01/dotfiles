{
  "layer": "top",
  "output": [
    "HDMI-A-1",
    "eDP-1"
  ],
  "modules-left": [
    "backlight",
    "wireplumber",
    "cpu",
    "mpris"
  ],
  "modules-center": [
    "hyprland/workspaces",
    "clock"
  ],
  "modules-right": [
    "power-profiles-daemon",
    "custom/bluetooth",
    "network",
    "memory",
    "tray",
    "battery"
  ],
  "wireplumber": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "¾░Ø¤ {volume}%",
    "on-click": "pavucontrol",
    "format-icons": [
      "’Ć”",
      "’Ć¦",
      "’Ć©"
    ]
  },
  "network": {
    "tooltip": true,
    "format-wifi": "’ć½ ",
    "rotate": 0,
    "format-ethernet": "¾░łĆ ",
    "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
    "format-linked": "¾░łĆ {ifname} (No IP)",
    "format-disconnected": "¾░¢¬ ",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 2,
    "on-click": "~/.config/rofi/iwmenu/iwmenu-waybar.sh"
  },
  "backlight": {
    "device": "intel_backlight",
    "rotate": 0,
    "format": "{icon} {percent}%",
    "format-icons": [
      "’ā½"
    ],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "rotate": 0,
    "format-charging": "’ć” {capacity}%",
    "format-plugged": "’ć” {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "¾░éÄ",
      "¾░ü║",
      "¾░ü╗",
      "¾░ü╝",
      "¾░üĮ",
      "¾░üŠ",
      "¾░ü┐",
      "¾░éĆ",
      "¾░éü",
      "¾░éé",
      "¾░ü╣"
    ]
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%m-%d-%Y}",
    "tooltip": false
  },
  "cpu": {
    "format": "’ŗø {usage}%",
    "on-click": "kitty -- btop",
    "tooltip": true
  },
  "tray": {
    "icon-size": 16,
    "rotate": 0,
    "spacing": 5
  },
  "memory": {
    "interval": 30,
    "format": "Ņ┐ģ  {used:0.1f}G/{total:0.1f}G",
    "max-length": 20
  },
  "custom/bluetooth": {
    "format": "’Ŗö {}",
    "exec": "~/.config/waybar/bluetooth-display.sh",
    "interval": 10,
    "on-click": "blueman-manager",
    "return-type": "plain",
    "tooltip": false,
    "max-length": 25
  },
  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "format-stopped": "",
    "ignore-list": [
      "vesktop"
    ],
    "player-icons": {
      "brave": "’ē®",
      "default": "’Ćü",
      "spotify": "’å╝",
      "vlc": "’ĆĮ",
      "mpv": "’ģä"
    },
    "status-icons": {
      "paused": "Ō¢Č",
      "playing": "ŌÅĖ"
    },
    "max-length": 40,
    "tooltip": true
  },
  "hyprland/workspaces": {
    "format": "{icon} {windows} ",
    "on-click": "activate",
    "window-rewrite-default": "",
    "window-rewrite": {
      "title<.*youtube.*>": "’ģ¬",
      "title<.*nvim*>": "’Ź»",
      "title<.*WhatsApp.*>": "’ł▓",
      "title<.*github.*>": "’éø",
      "title<.*gitlab.*>": "’Ŗ¢",
      "title<.*bitbucket.*>": "’ģ▒",
      "title<.*stackoverflow.*>": "’ģ¼",
      "title<.*stack overflow.*>": "’ģ¼",
      "title<.*vercel.*>": "Ō¢▓",
      "title<.*netlify.*>": "’Äź",
      "title<.*figma.*>": "’×Ö",
      "title<.*canva.*>": "’ĆŠ",
      "title<.*google docs.*>": "’ćé",
      "title<.*google sheets.*>": "’ćā",
      "title<.*google drive.*>": "’āć",
      "title<.*youtube music.*>": "’Ćü",
      "title<.*twitch.*>": "’ć©",
      "title<.*chatgpt.*>": "’Æ©",
      "title<.*openai.*>": "’Æ©",
      "title<.*gmail.*>": "’āĀ",
      "title<.*outlook.*>": "’āĀ",
      "title<.*prisma.*>": "Ņ×«",
      "title<.*docker.*>": "’īł",
      "title<.*kubernetes.*>": "¾▒āŠ",
      "title<.*aws.*>": "Ņ×Ł",
      "title<.*vercel dashboard.*>": "Ō¢▓",
      "title<Volume Control>": "¾░ĢŠ",
      "class<thunar>": "¾░ēŗ",
      "class<nautilus>": "¾░ēŗ",
      "class<pcmanfm>": "¾░ēŗ",
      "class<nm-connection-editor>": "¾░ż©",
      "class<obs>": "’ĆĮ",
      "class<gimp>": "’ć╝",
      "class<firefox>": "’ē®",
      "class<alacritty>": "’Æē",
      "class<discord>": "’ÄÆ",
      "class<spotify>": "’å╝",
      "class<code>": "¾░©×",
      "class<code-oss>": "¾░©×",
      "class<jetbrains-idea>": "Ņ×Ą",
      "class<postman>": "¾░ø«",
      "class<slack>": "’åś",
      "class<teams>": "¾░Ŗ╗",
      "class<signal>": "¾░Ź”",
      "class<telegram>": "’ŗå"
    },
    "active": "",
