{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "gruvbox",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{ .context7_api_key }}"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "deepseek": {
          "name": "deepseek-coder:6.7b"
        }
      }
    }
  },
  "autoupdate": true
}
